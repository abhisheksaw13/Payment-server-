{
  "name": "payment-server",
  "version": "1.0.0",
  "description": "Cashfree payment gateway integration with Node.js, Express, and MongoDB",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
